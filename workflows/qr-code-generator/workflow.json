{
  "name": "Acrewity Demo - QR Code Generator",
  "nodes": [
    {
      "parameters": {},
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
        12
      ],
      "id": "trigger-1",
      "name": "Manual Trigger"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "text",
              "value": "https://www.acrewity.com",
              "type": "string"
            },
            {
              "name": "size",
              "value": 300,
              "type": "number"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        224,
        12
      ],
      "id": "set-data-1",
      "name": "Set QR Data"
    },
    {
      "parameters": {
        "resource": "qr_code_generator",
        "text": "={{ $json.text }}",
        "size": "={{ $json.size }}"
      },
      "type": "@acrewity/n8n-nodes-acrewity.acrewityTool",
      "typeVersion": 1,
      "position": [
        456,
        112
      ],
      "id": "acrewity-qr-1",
      "name": "Generate QR Code",
      "credentials": {
        "acrewityApi": {
          "id": "YOUR_ACREWITY_CREDENTIAL_ID",
          "name": "Acrewity account"
        }
      }
    },
    {
      "parameters": {
        "resource": "qr_code_generator"
      },
      "type": "@acrewity/n8n-nodes-acrewity.acrewity",
      "typeVersion": 1,
      "position": [
        448,
        -80
      ],
      "id": "7a02fc4f-0809-4df0-a1b3-8c30fa4c21b5",
      "name": "Generate a QR code",
      "credentials": {
        "acrewityApi": {
          "id": "YOUR_ACREWITY_CREDENTIAL_ID",
          "name": "Acrewity account"
        }
      }
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Set QR Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Set QR Data": {
      "main": [
        [
          {
            "node": "Generate a QR code",
            "type": "main",
            "index": 0
          },
          {
            "node": "Generate QR Code",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "callerPolicy": "workflowsFromSameOwner",
    "availableInMCP": false
  },
  "pinData": {}
}
