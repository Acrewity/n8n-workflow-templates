      "typeVersion": 2.1,
      "position": [1100, 500],
      "parameters": {
        "name": "json_to_excel",
        "description": "Convert a JSON array of objects into a downloadable Excel spreadsheet. Each object becomes a row, keys become column headers. Use for tabular data, reports, or data export.",
        "source": "database",
        "workflowId": { "__rl": true, "value": "YOUR_DISPATCHER_WORKFLOW_ID", "mode": "id" },
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
            "service": "json-to-excel",
            "operation": "create_multi_sheet",
            "data": "={{ $fromAI('data', 'JSON array of objects as a string. Example: [{\"Name\":\"Alice\",\"Score\":95},{\"Name\":\"Bob\",\"Score\":87}]') }}",
            "sheetName": "={{ $fromAI('sheetName', 'Name for the Excel sheet tab', 'string', 'Sheet1') }}"
          },
          "schema": [
            { "id": "service", "displayName": "service", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "operation", "displayName": "operation", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "data", "displayName": "data", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "sheetName", "displayName": "sheetName", "type": "string", "required": false, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false }
          ]
        }
      }
    },
    {
      "id": "aia-0005-0001-0001-0001-000000000011",
