    },
    {
      "id": "a4000001-0001-0001-0001-000000000002",
      "name": "Fetch Page Content",
      "type": "@acrewity/n8n-nodes-acrewity.acrewity",
      "typeVersion": 1,
      "position": [
        220,
        0
      ],
      "parameters": {
        "resource": "url_to_markdown",
