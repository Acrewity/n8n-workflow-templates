{
  "name": "Acrewity AI Agent",
  "nodes": [
    {
      "id": "aia-0005-0001-0001-0001-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "acrewity-agent",
        "responseMode": "responseNode",
        "options": {}
      },
      "webhookId": "acrewity-agent-webhook-001"
    },
    {
      "id": "aia-0005-0001-0001-0001-000000000002",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.9,
      "position": [300, 0],
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.body.message }}",
        "options": {
          "systemMessage": "You are an Acrewity AI Agent — a powerful automation assistant with access to document, data, and utility tools.\n\nAvailable tools and when to use them:\n\n• generate_qr_code — encode any URL or text into a scannable QR image. Use when the user mentions QR codes, links, or wants something scannable.\n\n• convert_html_to_pdf — render HTML into a PDF document. Use for invoices, reports, certificates, or any formatted document request. You will write the full HTML yourself before calling this tool — make it look professional with inline CSS.\n\n• fetch_url_as_markdown — retrieve a webpage and return its content as clean Markdown. Use when the user wants to read, summarize, or process a webpage.\n\n• generate_uuid — produce unique identifiers. Use for creating IDs, tokens, keys, or anything requiring a unique string.\n\n• compare_texts — compute a line-by-line diff. Use when the user wants to compare documents, find changes, or audit differences.\n\n• json_to_excel — turn a JSON array into a downloadable Excel file. Use for any tabular data, reports, or data export requests.\n\nRules:\n- Always call the appropriate tool — do not describe what you would do, do it.\n- When generating PDFs, write complete, styled HTML first — use inline CSS, proper structure, a clean professional look.\n- Return the tool result in your response so the caller can use it directly.\n- Be concise in your text. The output file is the deliverable, not a long explanation."
        }
      }
    },
    {
      "id": "aia-0005-0001-0001-0001-000000000003",
      "name": "Claude (your model)",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [100, 300],
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "list",
          "value": "claude-sonnet-4-6",
          "cachedResultName": "Claude Sonnet 4.6"
        },
        "options": {}
      },
      "credentials": {
        "anthropicApi": {
          "id": "YOUR_ANTHROPIC_CREDENTIAL_ID",
          "name": "Anthropic account"
        }
      }
    },
    {
      "id": "aia-0005-0001-0001-0001-000000000004",
      "name": "generate_qr_code",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 2.1,
      "position": [0, 500],
      "parameters": {
        "name": "generate_qr_code",
        "description": "Generate a scannable QR code image from any text or URL. Returns base64-encoded PNG or SVG image data.",
        "source": "database",
        "workflowId": { "__rl": true, "value": "YOUR_DISPATCHER_WORKFLOW_ID", "mode": "id" },
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
            "service": "qr_code_generator",
            "operation": "generate_qr",
            "text": "={{ $fromAI('text', 'The text or URL to encode in the QR code') }}",
            "format": "={{ $fromAI('format', 'Output image format: png or svg', 'string', 'png') }}",
            "size": "={{ $fromAI('size', 'QR code size in pixels between 100 and 1000', 'number', 300) }}"
          },
          "schema": [
            { "id": "service", "displayName": "service", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "operation", "displayName": "operation", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "text", "displayName": "text", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "format", "displayName": "format", "type": "string", "required": false, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "size", "displayName": "size", "type": "number", "required": false, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false }
          ]
        }
      }
    },
    {
      "id": "aia-0005-0001-0001-0001-000000000005",
      "name": "convert_html_to_pdf",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 2.1,
      "position": [220, 500],
      "parameters": {
        "name": "convert_html_to_pdf",
        "description": "Convert an HTML string into a downloadable PDF document. For invoices, reports, certificates, or any formatted document. You must write complete styled HTML before calling this tool — include full <html><head><style>...</style></head><body>...</body></html> with inline CSS.",
        "source": "database",
        "workflowId": { "__rl": true, "value": "YOUR_DISPATCHER_WORKFLOW_ID", "mode": "id" },
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
            "service": "html-to-pdf",
            "operation": "convert_pdf",
            "html": "={{ $fromAI('html', 'Complete HTML document string to convert to PDF, with full <html><head><style></style></head><body></body></html> structure and inline CSS') }}"
          },
          "schema": [
            { "id": "service", "displayName": "service", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "operation", "displayName": "operation", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "html", "displayName": "html", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false }
          ]
        }
      }
    },
    {
      "id": "aia-0005-0001-0001-0001-000000000006",
      "name": "fetch_url_as_markdown",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 2.1,
      "position": [440, 500],
      "parameters": {
        "name": "fetch_url_as_markdown",
        "description": "Fetch any public webpage and convert its content to clean Markdown text. Use when the user wants to read, summarize, extract, or process the content of a URL.",
        "source": "database",
        "workflowId": { "__rl": true, "value": "YOUR_DISPATCHER_WORKFLOW_ID", "mode": "id" },
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
            "service": "url_to_markdown",
            "operation": "url_to_markdown",
            "url": "={{ $fromAI('url', 'The full URL of the webpage to fetch and convert to Markdown text') }}"
          },
          "schema": [
            { "id": "service", "displayName": "service", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "operation", "displayName": "operation", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "url", "displayName": "url", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false }
          ]
        }
      }
    },
    {
      "id": "aia-0005-0001-0001-0001-000000000007",
      "name": "generate_uuid",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 2.1,
      "position": [660, 500],
      "parameters": {
        "name": "generate_uuid",
        "description": "Generate one or more random UUIDs (v4). Use for IDs, tokens, keys, or any unique string.",
        "source": "database",
        "workflowId": { "__rl": true, "value": "YOUR_DISPATCHER_WORKFLOW_ID", "mode": "id" },
