          "schema": [
            { "id": "service", "displayName": "service", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "operation", "displayName": "operation", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "count", "displayName": "count", "type": "number", "required": false, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false }
          ]
        }
      }
    },
    {
      "id": "aia-0005-0001-0001-0001-000000000008",
      "name": "compare_texts",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 2.1,
      "position": [880, 500],
      "parameters": {
        "name": "compare_texts",
        "description": "Compare two pieces of text and return a line-by-line diff showing additions and deletions. Use to find differences between two versions of text, documents, or code.",
        "source": "database",
        "workflowId": { "__rl": true, "value": "YOUR_DISPATCHER_WORKFLOW_ID", "mode": "id" },
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
            "service": "text-diff",
            "operation": "compare_text",
            "text1": "={{ $fromAI('text1', 'The original text (before version)') }}",
            "text2": "={{ $fromAI('text2', 'The modified text (after version)') }}"
          },
          "schema": [
            { "id": "service", "displayName": "service", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "operation", "displayName": "operation", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "text1", "displayName": "text1", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false },
            { "id": "text2", "displayName": "text2", "type": "string", "required": true, "display": true, "canBeUsedToMatch": true, "defaultMatch": false, "removed": false }
          ]
        }
